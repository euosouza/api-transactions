          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/summary",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "summary"]
            },
            "description": "Retorna o saldo total (soma de todos os créditos menos todos os débitos) da sessão atual.\n\n⚠️ **Requer cookie de sessão** (`sessionId`).\n\n**Resposta:** `200 OK`\n```json\n{\n  \"amount\": 3500\n}\n```"
          },
          "response": [
            {
              "name": "200 - Sumário",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/transactions/summary",
